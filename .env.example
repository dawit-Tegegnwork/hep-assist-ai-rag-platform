# Optional PostgreSQL URL (SQLite used by default for local dev).
# MEDIMIND_DATABASE_URL=postgresql://medimind:medimind@localhost:5432/medimind

# Environment: development | staging | production
# MEDIMIND_ENVIRONMENT=development

# Override default JSONL audit log path when DB is unavailable.
# MEDIMIND_AUDIT_LOG_PATH=audit_logs.jsonl

# Embedding provider: mock (fast local/CI) or fastembed (pip install -r requirements-prod.txt)
# MEDIMIND_EMBEDDING_PROVIDER=mock
# MEDIMIND_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# MEDIMIND_RETRIEVAL_TOP_K=3
# MEDIMIND_RETRIEVAL_MIN_SCORE=0.35
# MEDIMIND_APPROVED_CONTENT_ONLY_DEFAULT=true

# Production ops
# MEDIMIND_LOG_LEVEL=INFO
# MEDIMIND_RATE_LIMIT_ENABLED=true
# MEDIMIND_RATE_LIMIT_PER_MINUTE=120
# MEDIMIND_AUTO_SEED_ON_STARTUP=true
# MEDIMIND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# MEDIMIND_FRONTEND_URL=http://localhost:5173

# Auth (regulatory workflow lab — synthetic demo credentials in README)
# MEDIMIND_AUTH_ENABLED=true
# MEDIMIND_AUTH_SECRET_KEY=synthetic-eris-demo-secret-change-in-production
# MEDIMIND_AUTH_TOKEN_EXPIRE_HOURS=8

# Optional OpenAI-compatible provider (mock used when unset).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
